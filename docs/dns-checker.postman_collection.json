{
	"info": {
		"name": "DNS Checker API",
		"description": "Postman collection for the DNS Checker Backend API.\n\nBase URL: http://localhost:3000\nAll DNS check endpoints are under /api/v1/check/",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "domain",
			"value": "google.com",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"health"
							]
						}
					}
				}
			]
		},
		{
			"name": "Fetch All Records",
			"item": [
				{
					"name": "All Records",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"domain\": \"{{domain}}\",\n\t\"dkimSelector\": \"google\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/check/all",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"check",
								"all"
							]
						}
					}
				}
			]
